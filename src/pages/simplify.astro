---
import Base from "@/src/layouts/Base.astro";
import SimplifyClient from "@/src/components/SimplifyClient";
---

<Base
  title="Simplify GPX Tracks Online — GPXKit"
  description="Dense GPX files get silently thinned when other tools import them. Simplify reduces point count on your own terms, entirely in your browser."
>
  <p class="mb-1 font-mono text-xs tracking-[0.2em] text-faint uppercase">No. 003 — Simplify</p>
  <h1 class="mb-3 text-4xl font-bold tracking-tight">Simplify a GPX track</h1>
  <p class="mb-10 max-w-xl text-muted">
    Import a dense recording into Garmin Connect or a similar tool and it may get silently thinned
    — losing the shape or turns you actually want. Simplify it yourself first, so you control
    what's kept.
  </p>
  <SimplifyClient client:only="react" />
</Base>
