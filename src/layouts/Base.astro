---
import "@/src/styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const ogImageUrl = new URL("/og-image.png", Astro.site).toString();
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const navLinks = [
  { href: "/view", label: "View" },
  { href: "/merge", label: "Merge" },
  { href: "/simplify", label: "Simplify" },
  { href: "/trim", label: "Trim" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={pageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <div class="mx-auto flex min-h-screen max-w-4xl flex-col px-6">
      <header class="flex items-center justify-between border-b border-line py-6">
        <a href="/" class="text-2xl font-bold tracking-tight">
          GPX<span class="text-trace">Kit</span>
        </a>
        <nav class="flex gap-5 font-mono text-xs tracking-[0.15em] uppercase">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class={
                  Astro.url.pathname === link.href
                    ? "text-trace"
                    : "text-muted transition-colors hover:text-paper"
                }
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </header>

      <main class="flex-1 py-10">
        <slot />
      </main>

      <footer class="border-t border-line py-6 font-mono text-xs tracking-[0.1em] text-faint uppercase">
        <p>GPXKit — GPS tracks stay in your browser. Nothing is ever uploaded.</p>
      </footer>
    </div>

    <!-- Cloudflare Web Analytics: cookieless page-view beacon. -->
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={JSON.stringify({ token: "a8d0966de2bf41a8b37cda56a823e6b9" })}
    ></script>
  </body>
</html>
